# ===== OpenRouter (LLM Provider) =====
OPENROUTER_API_KEY=sk-or-v1-...
# Used as HTTP-Referer header (required by OpenRouter)
SITE_URL=http://localhost:4321
OPENROUTER_SITE_NAME=TradingAgents POC

# ===== Alpaca Paper Trading =====
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
# Set to "true" for paper trading, "false" for live
ALPACA_PAPER=true
# Notional USD per trade (fractional shares)
ALPACA_NOTIONAL=100

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key bypasses Row Level Security — use in backend only
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0

# ===== FastAPI Backend =====
BACKEND_PORT=8000
# CORS origin — should match Astro frontend URL
BACKEND_CORS_ORIGIN=http://localhost:4321

# ===== Analysis Settings =====
# Comma-separated list of tickers to analyze
TARGET_TICKERS=AAPL,MSFT,GOOGL,NVDA,TSLA
# Seconds to wait between dispatching tasks for each ticker
# Respects OpenRouter free-tier rate limits
COOLDOWN_SECONDS=30

# ===== Optional: Data APIs =====
# Leave blank to use yfinance (free, no key required)
ALPHA_VANTAGE_API_KEY=

# ===== Auth (Supabase JWT) =====
# Found in Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe Dashboard, paste the price IDs here
STRIPE_PRO_PRICE_ID=price_...
STRIPE_CREDIT_PACK_PRICE_ID=price_...
# URLs Stripe redirects to after checkout
STRIPE_SUCCESS_URL=http://localhost:4321/?checkout=success
STRIPE_CANCEL_URL=http://localhost:4321/?checkout=cancelled

# ===== Optional: Other LLM Providers (not used in default config) =====
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
