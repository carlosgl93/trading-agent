FROM python:3.11-slim

WORKDIR /app

# Install system deps: build-essential for Python packages, redis-server for
# the in-process Redis broker used by the `redis` Fly process group.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    redis-server \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml .
COPY tradingagents/ ./tradingagents/
COPY backend/ ./backend/

# Install core package + backend extras
RUN pip install --no-cache-dir -e ".[backend]"

# Default: run FastAPI. Override with `command` in docker-compose or
# fly.toml [processes] for the worker / redis process groups.
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
