---
import "../styles/global.css";
import UserNav from "../components/UserNav";
import SystemStatus from "../components/SystemStatus";
import AnalysisEngine from "../components/AnalysisEngine";
import ScoutPanel from "../components/ScoutPanel";
import ScoutHistory from "../components/ScoutHistory";
import PortfolioMonitor from "../components/PortfolioMonitor";
import ExecutionLogs from "../components/ExecutionLogs";
import AgentActivityFeed from "../components/AgentActivityFeed";
import { TrendingUp } from "lucide-preact";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TradingAgents — Live Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Geist:wght@400;600&family=IBM+Plex+Mono:wght@400&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Hide until auth check completes to prevent flash */
      body { visibility: hidden; }
    </style>
  </head>
  <body class="min-h-screen">
    <script>
      import { supabase } from "../lib/supabase";
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = "/login";
      } else {
        document.body.style.visibility = "visible";
      }
    </script>

    <header class="bg-surface-900 border-b border-surface-600 px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-accent-amber/15 flex items-center justify-center">
          <TrendingUp size={18} class="text-accent-amber" />
        </div>
        <div>
          <h1
            class="text-sm font-semibold"
            style="font-family: 'Geist', sans-serif; color: var(--color-text-base)"
          >
            TradingAgents
          </h1>
          <p class="text-[11px]" style="color: var(--color-text-muted)">
            Multi-agent trading · OpenRouter · Alpaca Paper
          </p>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <SystemStatus client:load />
        <UserNav client:load />
      </div>
    </header>

    <main class="p-4 max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[22%_1fr_26%] gap-4 items-start">

        <!-- Left: Controls -->
        <div class="space-y-4">
          <AnalysisEngine client:load />
          <ScoutPanel client:load />
        </div>

        <!-- Center: Agent Activity (hero) -->
        <div class="space-y-4">
          <AgentActivityFeed client:load />
          <ScoutHistory client:load />
        </div>

        <!-- Right: Results -->
        <div class="space-y-4">
          <PortfolioMonitor client:load />
          <ExecutionLogs client:load />
        </div>

      </div>
    </main>
  </body>
</html>
