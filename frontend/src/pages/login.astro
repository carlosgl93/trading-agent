---
import "../styles/global.css";
import LoginForm from "../components/LoginForm";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TradingAgents — Sign in</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Geist:wght@400;600&family=IBM+Plex+Mono:wght@400&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="margin: 0; background: #0B0A00;">
    <script>
      // If already authenticated, skip login page
      import { supabase } from "../lib/supabase";
      const { data: { session } } = await supabase.auth.getSession();
      if (session) window.location.href = "/";
    </script>
    <LoginForm client:only="preact" />
  </body>
</html>
